{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(nix flake check)",
      "Bash(nix eval .#*)",
      "Bash(nix-instantiate --parse *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(nixos-option *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(cryptsetup luksFormat *)",
      "Bash(cryptsetup erase *)",
      "Bash(sgdisk *)",
      "Bash(gdisk *)",
      "Bash(fdisk *)",
      "Bash(parted *)",
      "Bash(wipefs *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(nixos-rebuild * --impure *)",
      "Bash(sed -i * /etc/*)",
      "Bash(sed -i * /mnt/*)",
      "Bash(echo * > /etc/*)",
      "Bash(echo * >> /etc/*)",
      "Bash(systemd-cryptenroll *)",
      "Bash(passwd *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(poweroff *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | grep -qiE '(nvme0n1p[1-5]|/dev/sda|/dev/disk)' && { echo 'BLOCKED: direct access to protected partitions forbidden' >&2; exit 2; } || exit 0"
          }
        ]
      }
    ]
  },
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  }
}
